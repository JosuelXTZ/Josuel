<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Futebol Ao Vivo</title>

<style>

body{
font-family: Arial, sans-serif;
margin:0;
background:#0b3d91;
color:white;
}

header{
background:white;
color:#0b3d91;
padding:15px;
text-align:center;
font-size:24px;
font-weight:bold;
}

.container{
padding:20px;
}

.jogo{
background:white;
color:black;
margin-bottom:15px;
padding:15px;
border-radius:10px;
box-shadow:0 4px 10px rgba(0,0,0,0.2);
}

.times{
display:flex;
justify-content:space-between;
font-size:18px;
font-weight:bold;
}

.placar{
text-align:center;
font-size:22px;
margin:10px 0;
}

.status{
text-align:center;
color:green;
font-weight:bold;
}

footer{
text-align:center;
padding:10px;
background:#072a63;
margin-top:20px;
}

</style>

</head>

<body>

<header>
⚽ Futebol Ao Vivo
</header>

<div class="container" id="jogos">
Carregando jogos...
</div>

<footer>
Site criado por Josuel
</footer>

<script>

async function carregarJogos(){

let url="https://www.scorebat.com/video-api/v3/";

let resposta=await fetch(url);
let dados=await resposta.json();

let container=document.getElementById("jogos");
container.innerHTML="";

dados.response.slice(0,15).forEach(jogo=>{

container.innerHTML+=`

<div class="jogo">

<div class="times">
<span>${jogo.title.split(" - ")[0]}</span>
<span>${jogo.title.split(" - ")[1]}</span>
</div>

<div class="placar">
⚽ Jogo recente
</div>

<div class="status">
${jogo.competition}
</div>

</div>

`;

});

}

carregarJogos();

</script>

</body>
</html>
